<?xml version="1.0" encoding="UTF-8"?>
<configuration scan="true" scanPeriod="30 seconds">
    <!-- 日志格式定义 -->
    <property name="LOG_PATTERN" value="%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{50} - %msg%n"/>
    <property name="LOG_CHARSET" value="UTF-8"/>

    <!-- 生产环境日志文件路径配置 -->
    <property name="PROD_LOG_PATH" value="/var/log/CoinSec/coinsec.log"/>
    <property name="PROD_LOG_ARCHIVE" value="/var/log/CoinSec/coinsec-%d{yyyy-MM-dd}.log"/>

    <!-- 1. 控制台输出（所有环境通用定义） -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>${LOG_PATTERN}</pattern>
            <charset>${LOG_CHARSET}</charset>
        </encoder>
    </appender>

    <!-- 环境区分配置 -->
    <!-- 开发环境 (dev)：只输出到控制台 -->
    <springProfile name="dev">
        <root level="DEBUG">
            <appender-ref ref="CONSOLE"/>
        </root>
        <logger name="com.example.service" level="DEBUG" additivity="false">
            <appender-ref ref="CONSOLE"/>
        </logger>
    </springProfile>

    <!-- 生产环境 (prod)：只输出到文件 -->
    <springProfile name="prod">
        <!-- 2. 生产环境文件输出（仅在prod环境下定义） -->
        <appender name="PROD_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
            <file>${PROD_LOG_PATH}</file>
            <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
                <fileNamePattern>${PROD_LOG_ARCHIVE}</fileNamePattern>
                <maxHistory>30</maxHistory>
            </rollingPolicy>
            <triggeringPolicy class="ch.qos.logback.core.rolling.SizeBasedTriggeringPolicy">
                <maxFileSize>10MB</maxFileSize>
            </triggeringPolicy>
            <encoder>
                <pattern>${LOG_PATTERN}</pattern>
                <charset>${LOG_CHARSET}</charset>
            </encoder>
        </appender>

        <root level="INFO">
            <appender-ref ref="PROD_FILE"/>
        </root>
        <logger name="com.example.service" level="DEBUG" additivity="false">
            <appender-ref ref="PROD_FILE"/>
        </logger>
    </springProfile>
</configuration>
