<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.coinsec.mapper.SysUserMapper">

    <select id="countByUserNameAndRole" resultType="int">
        SELECT COUNT(*)
        FROM sys_user
        WHERE role = #{role}
          and user_name = #{userName}
    </select>
</mapper>
